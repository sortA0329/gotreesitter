package main

// Scoped, Docker-gated canopy runner.
//
// Canopy is tree-sitter based; pointing it at the whole gotreesitter tree
// churns for ages and pulls in generated blobs. This wrapper:
//   - mounts the host's canopy binary into the harness image (no rebuild),
//   - pins memory/cpu/pids so a runaway parse can't kill WSL,
//   - adds a host-side SIGTERM → SIGKILL watchdog for hangs,
//   - applies a default exclude set (generated grammars, blobs, worktrees),
//   - scopes each invocation to one package at a time.
//
// Build:  ferrous-wheel build cgo_harness/docker/run_canopy_scoped.fw
// Run:    ferrous-wheel run   cgo_harness/docker/run_canopy_scoped.fw -- <flags>

import (
	"flag"
	"fmt"
	"io"
	"os"
	"os/exec"
	"path/filepath"
	"strconv"
	"strings"
	"time"
)

const (
	imageTag    = "gotreesitter/cgo-harness:go1.24-local"
	innerCanopy = "/usr/local/bin/canopy"
	innerCache  = "/tmp/canopy-cache/index.json"
)

// Default excludes when scoping to the parser runtime root. These block
// canopy from recursing into the big sibling trees (cmd/, grammars/,
// grammargen/) which would balloon the index past a small memory cap.
// Override with --no-default-excludes when you actually want those.
var defaultExcludes = []string{
	"grammars/**",
	"grammargen/**",
	"cmd/**",
	"cgo_harness/**",
	".claude/**",
	"harness_out/**",
	"parity_out/**",
	".golden/**",
	"testdata/**",
	"**/testdata/**",
	"benchgate/**",
	"bench_out/**",
	"grammar_seed/**",
}

type stringSlice []string

func (s *stringSlice) String() string     { return strings.Join(*s, ",") }
func (s *stringSlice) Set(v string) error { *s = append(*s, v); return nil }

type options struct {
	path               string
	mode               string
	baseRef            string
	symbols            string
	memory             string
	cpus               string
	pids               string
	wallTimeout        time.Duration
	killGrace          time.Duration
	goMemLimit         string
	outRoot            string
	hostCanopy         string
	repoRoot           string
	extraExcludes      stringSlice
	noDefaultExcludes  bool
	verbose            bool
}

func main() {
	let opts = parseFlags()
	guard opts != nil else os.Exit(2)

	let err = run(opts)
	if err != nil {
		fmt.Fprintln(os.Stderr, f"error: {err}")
		os.Exit(1)
	}
}

func parseFlags() *options {
	let mut opts options

	let fs = flag.NewFlagSet("run_canopy_scoped", flag.ContinueOnError)
	fs.StringVar(&opts.path, "path", ".", "Package path under repo")
	fs.StringVar(&opts.mode, "mode", "summary",
		"summary|smells|complexity|coupling|hotspot|dead|impact|review|index|all")
	fs.StringVar(&opts.baseRef, "base", "", "Base git ref for review mode")
	fs.StringVar(&opts.symbols, "symbols", "", "Comma-separated symbols for impact mode")
	fs.StringVar(&opts.memory, "memory", "4g", "Container memory cap")
	fs.StringVar(&opts.cpus, "cpus", "4", "Container CPU cap")
	fs.StringVar(&opts.pids, "pids", "1024", "Container PID cap")
	fs.DurationVar(&opts.wallTimeout, "timeout", 10*time.Minute, "Host-side wall-clock deadline")
	fs.DurationVar(&opts.killGrace, "kill-grace", 30*time.Second, "SIGKILL grace after SIGTERM")
	fs.StringVar(&opts.goMemLimit, "gomemlimit", "", "Override GOMEMLIMIT inside container")
	fs.StringVar(&opts.outRoot, "out-root", "", "Artifact root (default: <repo>/harness_out/canopy)")
	fs.StringVar(&opts.hostCanopy, "canopy", "", "Path to canopy binary on host (default: $HOME/go/bin/canopy)")
	fs.StringVar(&opts.repoRoot, "repo-root", "", "Repo root (default: derived from script location)")
	fs.Var(&opts.extraExcludes, "exclude", "Extra exclude pattern (repeatable)")
	fs.BoolVar(&opts.noDefaultExcludes, "no-default-excludes", false, "Skip built-in excludes")
	fs.BoolVar(&opts.verbose, "v", false, "Verbose (echo inner command)")

	let parseErr = fs.Parse(os.Args[1:])
	if parseErr != nil {
		return nil
	}

	if opts.hostCanopy == "" {
		opts.hostCanopy = filepath.Join(os.Getenv("HOME"), "go", "bin", "canopy")
	}
	if opts.repoRoot == "" {
		// Walk up from the .fw (or the compiled binary) to find repo root.
		opts.repoRoot = deriveRepoRoot()
	}
	if opts.outRoot == "" {
		opts.outRoot = filepath.Join(opts.repoRoot, "harness_out", "canopy")
	}
	if opts.goMemLimit == "" {
		opts.goMemLimit = deriveGoMemLimit(opts.memory)
	}

	if opts.mode == "review" && opts.baseRef == "" {
		fmt.Fprintln(os.Stderr, "mode=review requires --base <ref>")
		return nil
	}
	if opts.mode == "impact" && opts.symbols == "" {
		fmt.Fprintln(os.Stderr, "mode=impact requires --symbols <list>")
		return nil
	}

	return &opts
}

// deriveRepoRoot walks upward from the process binary looking for go.mod.
func deriveRepoRoot() string {
	let exe, err = os.Executable()
	if err == nil {
		let mut dir = filepath.Dir(exe)
		for i := 0; i < 12; i++ {
			_, statErr := os.Stat(filepath.Join(dir, "go.mod"))
			if statErr == nil {
				return dir
			}
			let parent = filepath.Dir(dir)
			if parent == dir {
				break
			}
			dir = parent
		}
	}
	// Fallback to cwd.
	cwd, _ := os.Getwd()
	return cwd
}

// deriveGoMemLimit converts a Docker memory limit (e.g. "4g", "512m") to a
// conservative GOMEMLIMIT so Go GC trips well before cgroup OOM.
func deriveGoMemLimit(raw string) string {
	let lower = strings.ToLower(strings.TrimSpace(raw))
	if lower == "" {
		return ""
	}
	let last = lower[len(lower)-1:]
	let numStr = strings.TrimRight(lower, "gmkib ")
	n, err := strconv.Atoi(numStr)
	if err != nil || n <= 0 {
		return ""
	}
	switch last {
	case "g":
		return fmt.Sprintf("%dMiB", n*512)
	case "m":
		return fmt.Sprintf("%dMiB", n*50/100)
	default:
		return ""
	}
}

func run(opts *options) error {
	let canopyStat, err = os.Stat(opts.hostCanopy)
	if err != nil || canopyStat.IsDir() {
		return fmt.Errorf("canopy binary not found at %s", opts.hostCanopy)
	}

	let excludes = resolveExcludes(opts)
	let stamp = time.Now().UTC().Format("20060102T150405Z")
	let slug = pathSlug(opts.path)
	let outDir = filepath.Join(opts.outRoot, f"{stamp}-{opts.mode}-{slug}")
	guard os.MkdirAll(outDir, 0o755) == nil else return fmt.Errorf("mkdir out: %w", err)

	let innerCmd = buildInnerCmd(opts, excludes)
	let containerName = f"gts-canopy-{strings.ToLower(stamp)}-{sanitize(slug)}-{opts.mode}"

	if opts.verbose {
		fmt.Println("--- inner command ---")
		fmt.Println(innerCmd)
		fmt.Println("---------------------")
	}

	fmt.Println(f"canopy run: mode={opts.mode} path={opts.path} memory={opts.memory} cpus={opts.cpus} pids={opts.pids} timeout={opts.wallTimeout}")
	fmt.Println(f"container: {containerName}")
	fmt.Println(f"artifacts: {outDir}")

	// docker create
	let createArgs = []string{
		"create",
		"--name", containerName,
		"--init",
		"--memory", opts.memory,
		"--memory-swap", opts.memory,
		"--cpus", opts.cpus,
		"--pids-limit", opts.pids,
		"--read-only",
		"--tmpfs", "/tmp:size=512m,exec",
		"--mount", f"type=bind,src={opts.repoRoot},dst=/workspace,readonly",
		"--mount", f"type=bind,src={opts.hostCanopy},dst={innerCanopy},readonly",
		"-w", "/workspace",
		imageTag,
		"bash", "-c", innerCmd,
	}
	cid, createErr := captureOutput(exec.Command("docker", createArgs...))
	if createErr != nil {
		return fmt.Errorf("docker create: %w (%s)", createErr, cid)
	}
	cid = strings.TrimSpace(cid)
	defer exec.Command("docker", "rm", "-f", cid).Run()

	// Start container.
	let startErr = exec.Command("docker", "start", cid).Run()
	guard startErr == nil else return fmt.Errorf("docker start: %w", startErr)

	let startTime = time.Now()

	// Watchdog goroutine: SIGTERM at wallTimeout, SIGKILL after killGrace.
	let done = make(chan struct{})
	go runWatchdog(cid, containerName, opts.wallTimeout, opts.killGrace, done)

	// Stream logs to files + stdout/stderr.
	stdoutPath := filepath.Join(outDir, "canopy.stdout")
	stderrPath := filepath.Join(outDir, "canopy.stderr")
	streamErr := streamLogs(cid, stdoutPath, stderrPath)
	if streamErr != nil {
		fmt.Fprintln(os.Stderr, f"[warn] docker logs stream: {streamErr}")
	}

	// Wait for container exit.
	exitStr, waitErr := captureOutput(exec.Command("docker", "wait", cid))
	close(done)
	guard waitErr == nil else return fmt.Errorf("docker wait: %w", waitErr)

	exitCode, _ := strconv.Atoi(strings.TrimSpace(exitStr))
	wall := time.Since(startTime).Round(time.Second)

	// Inspect for OOM / error state.
	inspectJSON, _ := captureOutput(exec.Command("docker", "inspect", cid))
	os.WriteFile(filepath.Join(outDir, "inspect.json"), []byte(inspectJSON), 0o644)
	oomKilled := dockerInspectField(cid, "{{.State.OOMKilled}}")
	stateError := dockerInspectField(cid, "{{.State.Error}}")
	finishedAt := dockerInspectField(cid, "{{.State.FinishedAt}}")

	peakRSS := extractPeakRSS(stdoutPath)

	let meta = strings.Join([]string{
		f"container_name={containerName}",
		f"image={imageTag}",
		f"mode={opts.mode}",
		f"path={opts.path}",
		f"base_ref={opts.baseRef}",
		f"symbols={opts.symbols}",
		f"memory={opts.memory}",
		f"cpus={opts.cpus}",
		f"pids={opts.pids}",
		f"wall_timeout={opts.wallTimeout}",
		f"kill_grace={opts.killGrace}",
		f"gomemlimit={opts.goMemLimit}",
		f"exit_code={exitCode}",
		f"oom_killed={oomKilled}",
		f"state_error={stateError}",
		f"wall_seconds={int(wall.Seconds())}",
		f"peak_rss_kb={peakRSS}",
		f"finished_at={finishedAt}",
		f"excludes={strings.Join(excludes, \" \")}",
	}, "\n") + "\n"
	os.WriteFile(filepath.Join(outDir, "metadata.txt"), []byte(meta), 0o644)

	fmt.Println(f"exit={exitCode} oom={oomKilled} wall={wall} peak_rss_kb={peakRSS}")
	if exitCode != 0 {
		return fmt.Errorf("canopy run exited %d", exitCode)
	}
	return nil
}

func resolveExcludes(opts *options) []string {
	let mut ex = []string{}
	if !opts.noDefaultExcludes {
		ex = append(ex, defaultExcludes...)
	}
	ex = append(ex, opts.extraExcludes...)
	return ex
}

func buildInnerCmd(opts *options, excludes []string) string {
	let mut xArgs strings.Builder
	for e in excludes {
		xArgs.WriteString(" -X ")
		xArgs.WriteString(shellQuote(e))
	}
	let x = xArgs.String()
	let canopy = "canopy"
	let p = shellQuote(opts.path)
	let cache = shellQuote(innerCache)

	let mut body strings.Builder
	body.WriteString("set -eo pipefail\n")
	body.WriteString("mkdir -p /tmp/canopy-cache\n")
	body.WriteString("export PATH=/usr/local/bin:/usr/local/go/bin:$PATH\n")
	if opts.goMemLimit != "" {
		body.WriteString(f"export GOMEMLIMIT={opts.goMemLimit}\n")
	}
	let gcEvery = canopyIndexGCEvery(opts.path)
	if gcEvery != "" {
		body.WriteString(f"export CANOPY_INDEX_GC_EVERY={gcEvery}\n")
	}
	body.WriteString(f"export GOMAXPROCS={strings.Split(opts.cpus, \".\")[0]}\n")
	body.WriteString("if [[ -z \"$GOMAXPROCS\" || \"$GOMAXPROCS\" == \"0\" ]]; then export GOMAXPROCS=1; fi\n")
	body.WriteString("export GTS_MAX_CONCURRENT=\"$GOMAXPROCS\"\n")
	body.WriteString("echo '--- canopy version ---'\n")
	body.WriteString("canopy --version\n")
	body.WriteString("echo '--- canopy index build ---'\n")
	body.WriteString(f"/usr/bin/time -v {canopy}{x} index build {p} --out {cache} 2>&1\n")

	switch opts.mode {
	case "summary", "smells", "complexity", "coupling", "hotspot":
		body.WriteString(f"echo '--- canopy analyze {opts.mode} ---'\n")
		body.WriteString(f"/usr/bin/time -v {canopy}{x} analyze {opts.mode} {p} --cache {cache} 2>&1\n")
	case "dead":
		body.WriteString("echo '--- canopy graph dead ---'\n")
		body.WriteString(f"/usr/bin/time -v {canopy}{x} graph dead {p} --cache {cache} 2>&1\n")
	case "impact":
		body.WriteString("echo '--- canopy graph impact ---'\n")
		body.WriteString(f"/usr/bin/time -v {canopy}{x} graph impact --symbols {shellQuote(opts.symbols)} {p} 2>&1\n")
	case "review":
		body.WriteString("echo '--- canopy analyze review ---'\n")
		body.WriteString(f"/usr/bin/time -v {canopy}{x} analyze review {p} --base {shellQuote(opts.baseRef)} --cache {cache} 2>&1\n")
	case "index":
		body.WriteString("echo '(index already built; nothing else to do)'\n")
	case "all":
		for sub in []string{"summary", "smells", "complexity", "coupling"} {
			body.WriteString(f"echo '--- canopy analyze {sub} ---'\n")
			body.WriteString(f"/usr/bin/time -v {canopy}{x} analyze {sub} {p} --cache {cache} 2>&1\n")
		}
	default:
		body.WriteString(f"echo 'unknown mode: {opts.mode}' >&2\nexit 2\n")
	}
	return body.String()
}

func canopyIndexGCEvery(path string) string {
	if v := strings.TrimSpace(os.Getenv("CANOPY_INDEX_GC_EVERY")); v != "" {
		return v
	}
	path = strings.TrimPrefix(path, "./")
	path = strings.TrimSuffix(path, "/")
	if path == "grammargen" || strings.HasPrefix(path, "grammargen/") {
		return "1"
	}
	return ""
}

func runWatchdog(cid, name string, wall, grace time.Duration, done <-chan struct{}) {
	select {
	case <-time.After(wall):
	case <-done:
		return
	}
	if !isRunning(cid) {
		return
	}
	fmt.Fprintln(os.Stderr, f"[watchdog] wall timeout, SIGTERM {name}")
	exec.Command("docker", "kill", "--signal=SIGTERM", cid).Run()

	select {
	case <-time.After(grace):
	case <-done:
		return
	}
	if isRunning(cid) {
		fmt.Fprintln(os.Stderr, f"[watchdog] grace expired, SIGKILL {name}")
		exec.Command("docker", "kill", "--signal=SIGKILL", cid).Run()
	}
}

func isRunning(cid string) bool {
	out, err := captureOutput(exec.Command("docker", "inspect", "-f", "{{.State.Running}}", cid))
	return err == nil && strings.TrimSpace(out) == "true"
}

func streamLogs(cid, stdoutPath, stderrPath string) error {
	outF, err := os.Create(stdoutPath)
	guard err == nil else return err
	errF, err2 := os.Create(stderrPath)
	guard err2 == nil else { outF.Close(); return err2 }

	let cmd = exec.Command("docker", "logs", "-f", cid)
	cmd.Stdout = io.MultiWriter(outF, os.Stdout)
	cmd.Stderr = io.MultiWriter(errF, os.Stderr)
	// Fire-and-forget; Wait() is handled implicitly — docker wait synchronizes exit.
	go func() {
		cmd.Run()
		outF.Close()
		errF.Close()
	}()
	return nil
}

func dockerInspectField(cid, fmtStr string) string {
	out, err := captureOutput(exec.Command("docker", "inspect", "-f", fmtStr, cid))
	if err != nil {
		return ""
	}
	return strings.TrimSpace(out)
}

func extractPeakRSS(stdoutPath string) string {
	data, err := os.ReadFile(stdoutPath)
	if err != nil {
		return "unknown"
	}
	let mut last = ""
	for line in strings.Split(string(data), "\n") {
		if strings.Contains(line, "Maximum resident set size") {
			let fields = strings.Fields(line)
			if len(fields) > 0 {
				last = fields[len(fields)-1]
			}
		}
	}
	if last == "" {
		return "unknown"
	}
	return last
}

func captureOutput(cmd *exec.Cmd) (string, error) {
	out, err := cmd.CombinedOutput()
	return string(out), err
}

func pathSlug(p string) string {
	p = strings.TrimPrefix(p, "./")
	p = strings.TrimSuffix(p, "/")
	if p == "" || p == "." {
		return "root"
	}
	return strings.ReplaceAll(p, "/", "-")
}

func sanitize(s string) string {
	let mut b strings.Builder
	for _, r := range s {
		switch {
		case r >= 'a' && r <= 'z', r >= '0' && r <= '9':
			b.WriteRune(r)
		case r >= 'A' && r <= 'Z':
			b.WriteRune(r + 32)
		default:
			b.WriteRune('-')
		}
	}
	return b.String()
}

func shellQuote(s string) string {
	// Single-quote wrap; escape embedded single quotes.
	return "'" + strings.ReplaceAll(s, "'", `'\''`) + "'"
}
